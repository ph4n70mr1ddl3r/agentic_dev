{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic.dev/platform-spec/schemas/entity.schema.json",
  "title": "Entity",
  "description": "A model-driven business entity. Maps to a Postgres table ent_<id> with typed columns + extras JSONB (ADR-0002). Must declare a primary 'id' field; transactional+companyScoped entities must declare a companyId lookup to Company (ADR-0004).",
  "type": "object",
  "required": ["id", "name", "label", "scope", "companyScoped", "fields"],
  "additionalProperties": false,
  "properties": {
    "id": { "$ref": "_common.schema.json#/$defs/slug" },
    "name": { "$ref": "_common.schema.json#/$defs/typeName" },
    "label": { "$ref": "_common.schema.json#/$defs/localizedText" },
    "description": { "type": "string" },
    "scope": {
      "type": "string",
      "enum": ["transactional", "master"],
      "description": "master = shared reference data; transactional = company-scoped business records (ADR-0004)."
    },
    "companyScoped": {
      "type": "boolean",
      "description": "Whether records carry companyId. Master data may be shared across companies (ADR-0004)."
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "field.schema.json" },
      "contains": {
        "description": "Every entity has a guid primary key named 'id'.",
        "type": "object",
        "properties": { "name": { "const": "id" }, "type": { "const": "guid" } },
        "required": ["name", "type"]
      }
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "relationship.schema.json" }
    },
    "indexes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "fields"],
        "additionalProperties": false,
        "properties": {
          "name": { "$ref": "_common.schema.json#/$defs/slug" },
          "fields": { "type": "array", "minItems": 1, "items": { "$ref": "_common.schema.json#/$defs/fieldName" } },
          "unique": { "type": "boolean", "default": false }
        }
      }
    },
    "audit": { "type": "boolean", "default": true, "description": "Append-only version history in audit.* (ADR-0002)." },
    "timestamps": { "type": "boolean", "default": true, "description": "createdAt/updatedAt managed columns." },
    "category": { "type": "string" },
    "icon": { "type": "string" }
  },
  "allOf": [
    {
      "description": "Transactional + companyScoped entities must declare a companyId lookup to Company (ADR-0004).",
      "if": {
        "properties": { "scope": { "const": "transactional" }, "companyScoped": { "const": true } },
        "required": ["scope", "companyScoped"]
      },
      "then": {
        "properties": {
          "fields": {
            "contains": {
              "type": "object",
              "properties": {
                "name": { "const": "companyId" },
                "type": { "const": "lookup" },
                "lookup": {
                  "type": "object",
                  "required": ["target"],
                  "properties": { "target": { "const": "Company" } }
                }
              },
              "required": ["name", "type", "lookup"]
            }
          }
        }
      }
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic.dev/platform-spec/schemas/domain-reference.schema.json",
  "title": "Domain reference",
  "description": "A structured, schema-validated digest of a Dynamics 365 business area (Financials or Supply Chain). Authored by the Domain Modeler as ground truth for downstream agents (ADR-0005 curated reference KB); rendered to markdown for humans. The $kind discriminator lets the harness detect it.",
  "type": "object",
  "required": ["$kind", "id", "name", "label", "area", "entities"],
  "additionalProperties": false,
  "properties": {
    "$kind": { "const": "domain-reference" },
    "id": { "$ref": "_common.schema.json#/$defs/slug" },
    "name": { "$ref": "_common.schema.json#/$defs/typeName" },
    "label": { "$ref": "_common.schema.json#/$defs/localizedText" },
    "area": {
      "type": "string",
      "enum": ["financials", "supply-chain"],
      "description": "Which D365 business area this digest covers."
    },
    "description": { "type": "string" },
    "source": {
      "type": "string",
      "description": "Provenance — e.g. the D365 docs area; note if model-reconstructed."
    },
    "version": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)*$" },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/domainEntity" }
    },
    "processes": { "type": "array", "items": { "$ref": "#/$defs/process" } },
    "rules": { "type": "array", "items": { "$ref": "#/$defs/rule" } }
  },
  "$defs": {
    "domainField": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "_common.schema.json#/$defs/fieldName" },
        "type": {
          "type": "string",
          "enum": ["text", "integer", "decimal", "money", "boolean", "date", "datetime", "time", "picklist", "lookup", "guid", "json"]
        },
        "label": { "$ref": "_common.schema.json#/$defs/localizedText" },
        "description": { "type": "string" },
        "required": { "type": "boolean" }
      }
    },
    "domainRelationship": {
      "type": "object",
      "required": ["name", "target"],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "_common.schema.json#/$defs/fieldName" },
        "target": { "type": "string", "description": "Name of the related domain concept." },
        "cardinality": { "type": "string", "enum": ["one-to-one", "one-to-many", "many-to-one", "many-to-many"] },
        "description": { "type": "string" }
      }
    },
    "domainEntity": {
      "type": "object",
      "required": ["name", "label", "category", "fields"],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "_common.schema.json#/$defs/typeName" },
        "label": { "$ref": "_common.schema.json#/$defs/localizedText" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["transactional", "master", "reference"] },
        "fields": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/domainField" } },
        "relationships": { "type": "array", "items": { "$ref": "#/$defs/domainRelationship" } },
        "source": { "type": "string", "description": "Where in D365 docs this concept comes from." }
      }
    },
    "process": {
      "type": "object",
      "required": ["name", "label"],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "_common.schema.json#/$defs/typeName" },
        "label": { "$ref": "_common.schema.json#/$defs/localizedText" },
        "description": { "type": "string" },
        "steps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "entities": { "type": "array", "items": { "type": "string" }, "description": "Domain concepts involved." },
        "triggers": { "type": "array", "items": { "type": "string", "enum": ["manual", "scheduled", "event", "workflow"] } }
      }
    },
    "rule": {
      "type": "object",
      "required": ["name", "label", "description"],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "_common.schema.json#/$defs/typeName" },
        "label": { "$ref": "_common.schema.json#/$defs/localizedText" },
        "description": { "type": "string" },
        "enforced": {
          "type": "string",
          "enum": ["before-create", "before-update", "before-post", "on-submit", "on-approve", "constant"]
        },
        "severity": { "type": "string", "enum": ["error", "warning", "info"] }
      }
    }
  }
}

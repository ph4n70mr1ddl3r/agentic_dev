{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic.dev/platform-spec/schemas/rule.schema.json",
  "title": "Business rule",
  "description": "An event-triggered rule: when the JSON-logic condition holds, fire the curated actions (ADR-0003).",
  "type": "object",
  "required": ["id", "name", "label", "entity", "trigger", "condition", "actions"],
  "additionalProperties": false,
  "properties": {
    "id": { "$ref": "_common.schema.json#/$defs/slug" },
    "name": { "$ref": "_common.schema.json#/$defs/typeName" },
    "label": { "$ref": "_common.schema.json#/$defs/localizedText" },
    "entity": { "$ref": "_common.schema.json#/$defs/typeName" },
    "trigger": {
      "type": "string",
      "enum": ["before-create", "after-create", "before-update", "after-update", "before-delete", "after-delete", "on-field-change", "on-post"]
    },
    "condition": { "$ref": "json-logic.schema.json" },
    "actions": { "type": "array", "minItems": 1, "items": { "$ref": "action.schema.json" } },
    "priority": { "type": "integer", "default": 100 },
    "enabled": { "type": "boolean", "default": true },
    "stopOnFire": { "type": "boolean", "default": false, "description": "Halt further rule evaluation when this rule fires." },
    "field": { "$ref": "_common.schema.json#/$defs/fieldName", "description": "Required when trigger is on-field-change." }
  },
  "allOf": [
    {
      "if": { "properties": { "trigger": { "const": "on-field-change" } }, "required": ["trigger"] },
      "then": { "required": ["field"] }
    }
  ]
}

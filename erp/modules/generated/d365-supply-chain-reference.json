  "rules": [
    {
      "description": "Inventory on-hand quantity must not become negative after a transaction.",
      "enforced": "before-post",
      "label": {
        "en": "Negative Inventory Not Allowed"
      },
      "name": "NegativeInventory",
      "severity": "error"
    },
    {
      "description": "Purchase orders above a certain amount must be approved before they can be confirmed.",
      "enforced": "before-update",
      "label": {
        "en": "Purchase Order Approval Required"
      },
      "name": "PurchaseOrderApproval",
      "severity": "error"
    },
    {
      "description": "Sales order cannot exceed the customer's credit limit without approval.",
      "enforced": "before-create",
      "label": {
        "en": "Customer Credit Limit Check"
      },
      "name": "SalesOrderCreditLimit",
      "severity": "warning"
    },
    {

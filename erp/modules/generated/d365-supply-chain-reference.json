  "id": "d365-supply-chain-reference",
  "label": {
    "en": "Dynamics 365 Supply Chain Management Reference"
  },
  "name": "D365SupplyChainReference",
  "processes": [
    {
      "description": "Process of creating, approving, and receiving a purchase order.",
      "entities": [
        "PurchaseOrder",
        "PurchaseOrderLine",
        "Vendor",
        "Product",
        "InventoryTransaction"
      ],
      "label": {
        "en": "Purchase Order Procurement"
      },
      "name": "PurchaseOrderProcurement",
      "steps": [
        "Create purchase order header with vendor and dates",
        "Add purchase order lines with products and quantities",
        "Submit for approval",
        "Approve purchase order",
        "Receive products against purchase order lines",
        "Update inventory transactions with receipt"
      ],
      "triggers": [
        "manual",
        "workflow"
      ]
    },
    {
      "description": "Process of creating, confirming, and shipping a sales order.",
      "entities": [
        "SalesOrder",
        "SalesOrderLine",
        "Customer",
        "Product",
        "InventoryTransaction"
      ],
      "label": {
        "en": "Sales Order Fulfillment"
      },
      "name": "SalesOrderFulfillment",
      "steps": [
        "Create sales order header with customer and dates",
        "Add sales order lines with products and quantities",
        "Confirm sales order",
        "Reserve inventory",
        "Pick and pack products",
        "Ship products and update inventory transactions"
      ],
      "triggers": [
        "manual",
        "workflow"
      ]
    },
    {
      "description": "Process of moving inventory from one warehouse to another.",
      "entities": [
        "InventoryTransaction",
        "Product",
        "Warehouse"
      ],
      "label": {
        "en": "Inventory Transfer"
      },
      "name": "InventoryTransfer",
      "steps": [
        "Create transfer order",
        "Specify source and destination warehouses",
        "Add products and quantities",
        "Ship from source warehouse",
        "Receive at destination warehouse",
        "Update inventory transactions for both warehouses"
      ],
      "triggers": [
        "manual"
      ]
    }
  ],
  "rules": [
    {
      "description": "Inventory quantity for a product cannot go below zero unless configured otherwise.",
      "enforced": "before-update",
      "label": {
        "en": "Negative Inventory Not Allowed"
      },
      "name": "NegativeInventoryNotAllowed",
      "severity": "error"
    },
    {
      "description": "Quantity on a purchase order line must be greater than zero.",
      "enforced": "before-create",
      "label": {

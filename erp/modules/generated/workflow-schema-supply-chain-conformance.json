{
  "$kind": "test-plan",
  "area": "supply-chain",
  "assertions": [
    {
      "expect": "valid",
      "name": "represents-procure-to-pay-workflow",
      "rationale": "The workflow schema must represent the Procure to Pay process with states and transitions.",
      "sample": {
        "description": "End-to-end process from purchase requisition to vendor payment.",
        "entity": "PurchaseOrder",
        "id": "procure-to-pay",
        "initialState": "draft",
        "label": {
          "en": "Procure to Pay"
        },
        "name": "ProcureToPay",
        "states": [
          {
            "label": {
              "en": "Draft"
            },
            "name": "draft"
          },
          {
            "label": {
              "en": "Approved"
            },
            "name": "approved"
          },
          {
            "label": {
              "en": "Received"
            },
            "name": "received"
          },
          {
            "label": {
              "en": "Invoiced"
            },
            "name": "invoiced",
            "terminal": true
          }
        ],
        "transitions": [
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": "approved"
              }
            ],
            "from": [
              "draft"
            ],
            "guard": {
              ">": [
                {
                  "var": "totalAmount"
                },
                0
              ]
            },
            "label": {
              "en": "Approve"
            },
            "name": "approve",
            "to": "approved"
          },
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": "received"
              }
            ],
            "from": [
              "approved"
            ],
            "label": {
              "en": "Receive"
            },
            "name": "receive",
            "to": "received"
          },
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": "invoiced"
              }
            ],
            "from": [
              "received"
            ],
            "label": {
              "en": "Invoice"
            },
            "name": "invoice",
            "to": "invoiced"
          }
        ]
      },
      "schema": "https://agentic.dev/platform-spec/schemas/workflow.schema.json",
      "source": "d365-supply-chain-reference/ProcureToPay"
    },
    {
      "expect": "valid",
      "name": "represents-order-to-cash-workflow",
      "rationale": "The workflow schema must represent the Order to Cash process.",
      "sample": {
        "description": "End-to-end process from sales order to customer payment.",
        "entity": "SalesOrder",
        "id": "order-to-cash",
        "initialState": "open",
        "label": {
          "en": "Order to Cash"
        },
        "name": "OrderToCash",
        "states": [
          {
            "label": {
              "en": "Open"
            },
            "name": "open"
          },
          {
            "label": {
              "en": "Shipped"
            },
            "name": "shipped"
          },
          {
            "label": {
              "en": "Invoiced"
            },
            "name": "invoiced",
            "terminal": true
          }
        ],
        "transitions": [
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": "shipped"
              }
            ],
            "from": [
              "open"
            ],
            "label": {
              "en": "Ship"
            },
            "name": "ship",
            "to": "shipped"
          },
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": "invoiced"
              }
            ],
            "from": [
              "shipped"
            ],
            "label": {
              "en": "Invoice"
            },
            "name": "invoice",
            "to": "invoiced"
          }
        ]
      },
      "schema": "https://agentic.dev/platform-spec/schemas/workflow.schema.json",
      "source": "d365-supply-chain-reference/OrderToCash"
    },
    {
      "expect": "valid",
      "name": "represents-production-execution-workflow",
      "rationale": "The workflow schema must represent the Production Execution process with multiple states and transitions.",
      "sample": {
        "description": "Process to manufacture a product from a production order.",
        "entity": "ProductionOrder",
        "id": "production-execution",
        "initialState": "created",
        "label": {
          "en": "Production Execution"
        },
        "name": "ProductionExecution",
        "states": [
          {
            "label": {
              "en": "Created"
            },
            "name": "created"
          },
          {
            "label": {
              "en": "Estimated"
            },
            "name": "estimated"
          },
          {
            "label": {
              "en": "Scheduled"
            },
            "name": "scheduled"
          },
          {
            "label": {
              "en": "Released"
            },
            "name": "released"
          },
          {
            "label": {
              "en": "Started"
            },
            "name": "started"
          },
          {
            "label": {
              "en": "Finished"
            },
            "name": "finished",
            "terminal": true
          }
        ],
        "transitions": [
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": "estimated"
              }
            ],
            "from": [
              "created"
            ],
            "label": {
              "en": "Estimate"
            },
            "name": "estimate",
            "to": "estimated"
          },
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": "scheduled"
              }
            ],
            "from": [
              "estimated"
            ],
            "guard": {
              "and": [
                {
                  "var": "scheduledStartDate"
                },
                {
                  "var": "scheduledEndDate"
                }
              ]
            },
            "label": {
              "en": "Schedule"
            },
            "name": "schedule",
            "to": "scheduled"
          },
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": "released"
              }
            ],
            "from": [
              "scheduled"
            ],
            "label": {
              "en": "Release"
            },
            "name": "release",
            "to": "released"
          },
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": "started"
              }
            ],
            "from": [
              "released"
            ],
            "label": {
              "en": "Start"
            },
            "name": "start",
            "to": "started"
          },
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": "finished"
              }
            ],
            "from": [
              "started"
            ],
            "label": {
              "en": "Finish"
            },
            "name": "finish",
            "to": "finished"
          }
        ]
      },
      "schema": "https://agentic.dev/platform-spec/schemas/workflow.schema.json",
      "source": "d365-supply-chain-reference/ProductionExecution"
    },
    {
      "expect": "valid",
      "name": "represents-inventory-transfer-workflow",
      "rationale": "The workflow schema must represent the Inventory Transfer process.",
      "sample": {
        "description": "Process to move inventory between warehouses.",
        "entity": "TransferOrder",
        "id": "inventory-transfer",
        "initialState": "created",
        "label": {
          "en": "Inventory Transfer"
        },
        "name": "InventoryTransfer",
        "states": [
          {
            "label": {
              "en": "Created"
            },
            "name": "created"
          },
          {
            "label": {
              "en": "Shipped"
            },
            "name": "shipped"
          },
          {
            "label": {
              "en": "Received"
            },
            "name": "received",
            "terminal": true
          }
        ],
        "transitions": [
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": "shipped"
              }
            ],
            "from": [
              "created"
            ],
            "label": {
              "en": "Ship"
            },
            "name": "ship",
            "to": "shipped"
          },
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": "received"
              }
            ],
            "from": [
              "shipped"
            ],
            "label": {
              "en": "Receive"
            },
            "name": "receive",
            "to": "received"
          }
        ]
      },
      "schema": "https://agentic.dev/platform-spec/schemas/workflow.schema.json",
      "source": "d365-supply-chain-reference/InventoryTransfer"
    },
    {
      "expect": "invalid",
      "name": "rejects-missing-initial-state",
      "rationale": "Missing required field 'initialState'.",
      "sample": {
        "entity": "PurchaseOrder",
        "id": "bad-workflow",
        "label": {
          "en": "Bad Workflow"
        },
        "name": "BadWorkflow",
        "states": [
          {
            "label": {
              "en": "Draft"
            },
            "name": "draft"
          }
        ],
        "transitions": []
      },
      "schema": "https://agentic.dev/platform-spec/schemas/workflow.schema.json",
      "source": "constraint:required"
    },
    {
      "expect": "invalid",
      "name": "rejects-transition-without-from",
      "rationale": "Transition missing required field 'from'.",
      "sample": {
        "entity": "PurchaseOrder",
        "id": "bad-transition",
        "initialState": "draft",
        "label": {
          "en": "Bad Transition"
        },
        "name": "BadTransition",
        "states": [
          {
            "label": {
              "en": "Draft"
            },
            "name": "draft"
          },
          {
            "label": {
              "en": "Approved"
            },
            "name": "approved"
          }
        ],
        "transitions": [
          {
            "label": {
              "en": "Approve"
            },
            "name": "approve",
            "to": "approved"
          }
        ]
      },
      "schema": "https://agentic.dev/platform-spec/schemas/workflow.schema.json",
      "source": "constraint:required"
    },
    {
      "expect": "invalid",
      "name": "rejects-empty-states-array",
      "rationale": "States array must have at least 1 item.",
      "sample": {
        "entity": "PurchaseOrder",
        "id": "empty-states",
        "initialState": "draft",
        "label": {
          "en": "Empty States"
        },
        "name": "EmptyStates",
        "states": [],
        "transitions": []
      },
      "schema": "https://agentic.dev/platform-spec/schemas/workflow.schema.json",
      "source": "constraint:minItems"
    }
  ],
  "description": "Validates that the workflow schema can represent typical procurement and inventory workflows from the D365 Supply Chain reference, and rejects missing required fields.",
  "id": "workflow-schema-supply-chain-conformance",
  "label": {
    "en": "Workflow schema — Supply Chain conformance"
  },
  "name": "WorkflowSchemaSupplyChainConformance",
  "reference": "d365-supply-chain-reference",
  "schema": "https://agentic.dev/platform-spec/schemas/workflow.schema.json"
}

{
  "$kind": "test-plan",
  "area": "supply-chain",
  "assertions": [
    {
      "expect": "valid",
      "name": "represents-purchase-order-approval-workflow",
      "rationale": "The workflow schema must represent a purchase order approval workflow with states and transitions.",
      "sample": {
        "description": "Workflow for approving purchase orders above a threshold.",
        "entity": "PurchaseOrder",
        "id": "po-approval",
        "initialState": "draft",
        "label": {
          "en": "Purchase Order Approval"
        },
        "name": "PurchaseOrderApproval",
        "states": [
          {
            "label": {
              "en": "Draft"
            },
            "name": "draft"
          },
          {
            "label": {
              "en": "Pending Approval"
            },
            "name": "pending-approval"
          },
          {
            "label": {
              "en": "Approved"
            },
            "name": "approved",
            "terminal": true
          },
          {
            "label": {
              "en": "Rejected"
            },
            "name": "rejected",
            "terminal": true
          }
        ],
        "transitions": [
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": {
                  "var": "pending-approval"
                }
              }
            ],
            "from": [
              "draft"
            ],
            "guard": {
              "==": [
                {
                  "var": "totalAmount"
                },
                {
                  "var": "totalAmount"
                }
              ]
            },
            "label": {
              "en": "Submit for Approval"
            },
            "name": "submit",
            "to": "pending-approval"
          },
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": {
                  "var": "approved"
                }
              }
            ],
            "from": [
              "pending-approval"
            ],
            "label": {
              "en": "Approve"
            },
            "name": "approve",
            "to": "approved"
          },
          {
            "actions": [
              {
                "action": "set-field",
                "field": "status",
                "value": {
                  "var": "rejected"
                }
              }
            ],
            "from": [
              "pending-approval"
            ],
            "label": {
              "en": "Reject"
            },
            "name": "reject",
            "to": "rejected"
          }
        ]
      },
      "schema": "https://agentic.dev/platform-spec/schemas/workflow.schema.json",
      "source": "d365-supply-chain-reference/ProcureToPay"
    },
    {
      "expect": "valid",
      "name": "represents-inventory-count-workflow",
      "rationale": "The workflow schema must represent an inventory count workflow with actions.",
      "sample": {
        "description": "Workflow for counting inventory and adjusting quantities.",
        "entity": "InventoryOnHand",
        "id": "inventory-count",
        "initialState": "open",
        "label": {
          "en": "Inventory Count"
        },
        "name": "InventoryCount",
        "states": [
          {
            "label": {
              "en": "Open"
            },
            "name": "open"
          },
          {
            "label": {
              "en": "Counted"
            },
            "name": "counted"
          },
          {
            "label": {
              "en": "Adjusted"
            },
            "name": "adjusted",
            "terminal": true
          }
        ],
        "transitions": [
          {
            "actions": [
              {
                "action": "update-record",
                "entity": "InventoryOnHand",
                "fields": {
                  "quantity": {
                    "var": "countedQuantity"
                  }
                }
              }
            ],
            "from": [
              "open"
            ],
            "label": {
              "en": "Record Count"
            },
            "name": "record-count",
            "to": "counted"
          },
          {
            "actions": [
              {
                "action": "set-field",
                "field": "lastUpdated",
                "value": {
                  "var": "now"
                }
              }
            ],
            "from": [
              "counted"
            ],
            "label": {
              "en": "Adjust"
            },
            "name": "adjust",
            "to": "adjusted"
          }
        ]
      },
      "schema": "https://agentic.dev/platform-spec/schemas/workflow.schema.json",
      "source": "d365-supply-chain-reference/InventoryOnHand"
    },
    {
      "expect": "invalid",
      "name": "rejects-missing-initial-state",
      "rationale": "The workflow schema requires 'initialState' property.",
      "sample": {
        "entity": "PurchaseOrder",
        "id": "bad-workflow",
        "label": {
          "en": "Bad Workflow"
        },
        "name": "BadWorkflow",
        "states": [
          {
            "label": {
              "en": "Draft"
            },
            "name": "draft"
          }
        ],
        "transitions": []
      },
      "schema": "https://agentic.dev/platform-spec/schemas/workflow.schema.json",
      "source": "constraint:workflow.schema.json"
    },
    {
      "expect": "invalid",
      "name": "rejects-transition-without-from",
      "rationale": "Each transition must have a 'from' array.",
      "sample": {
        "entity": "PurchaseOrder",
        "id": "bad-transition",
        "initialState": "draft",
        "label": {
          "en": "Bad Transition"
        },
        "name": "BadTransition",
        "states": [
          {
            "label": {
              "en": "Draft"
            },
            "name": "draft"
          },
          {
            "label": {
              "en": "Approved"
            },
            "name": "approved",
            "terminal": true
          }
        ],
        "transitions": [
          {
            "label": {
              "en": "Approve"
            },
            "name": "approve",
            "to": "approved"
          }
        ]
      },
      "schema": "https://agentic.dev/platform-spec/schemas/workflow.schema.json",
      "source": "constraint:workflow.schema.json"
    },
    {
      "expect": "invalid",
      "name": "rejects-state-without-name",
      "rationale": "Each state must have a 'name' property.",
      "sample": {
        "entity": "PurchaseOrder",
        "id": "bad-state",
        "initialState": "draft",
        "label": {
          "en": "Bad State"
        },
        "name": "BadState",
        "states": [
          {
            "label": {
              "en": "Draft"
            }
          }
        ],
        "transitions": []
      },
      "schema": "https://agentic.dev/platform-spec/schemas/workflow.schema.json",
      "source": "constraint:workflow.schema.json"
    }
  ],
  "description": "Checks that workflow.schema.json can represent typical procurement and inventory workflows from the D365 Supply Chain reference, and rejects missing required fields.",
  "id": "workflow-schema-supply-chain-conformance",
  "label": {
    "en": "Workflow schema — Supply Chain conformance"
  },
  "name": "WorkflowSchemaSupplyChainConformance",
  "reference": "d365-supply-chain-reference",
  "schema": "https://agentic.dev/platform-spec/schemas/workflow.schema.json"
}

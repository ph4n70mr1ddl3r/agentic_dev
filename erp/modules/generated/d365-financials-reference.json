  "id": "d365-financials-reference",
  "label": {
    "en": "Dynamics 365 Financials Reference"
  },
  "name": "D365FinancialsReference",
  "processes": [
    {
      "description": "Validate and post a journal entry to the general ledger.",
      "entities": [
        "JournalEntry",
        "JournalLine",
        "GeneralLedger",
        "LedgerAccount"
      ],
      "label": {
        "en": "Journal Posting"
      },
      "name": "JournalPosting",
      "steps": [
        "Create or open a journal entry",
        "Enter journal lines with debit and credit amounts",
        "Validate the entry balances (debits = credits)",
        "Post the journal entry",
        "Update general ledger account balances"
      ],
      "triggers": [
        "manual",
        "workflow"
      ]
    },
    {
      "description": "Record and pay a purchase invoice from a vendor.",
      "entities": [
        "PurchaseInvoice",
        "Vendor",
        "Payment",
        "GeneralLedger"
      ],
      "label": {
        "en": "Vendor Invoice Processing"
      },
      "name": "VendorInvoiceProcessing",
      "steps": [
        "Receive purchase invoice from vendor",
        "Match invoice to purchase order or receipt",
        "Record invoice in accounts payable",
        "Approve invoice for payment",
        "Generate payment to vendor",
        "Post payment and settle invoice"
      ],
      "triggers": [
        "manual",
        "workflow"
      ]
    },
    {
      "description": "Issue and collect payment for a sales invoice.",
      "entities": [
        "SalesInvoice",
        "Customer",
        "Payment",
        "GeneralLedger"
      ],
      "label": {
        "en": "Customer Invoice Processing"
      },
      "name": "CustomerInvoiceProcessing",
      "steps": [
        "Create sales invoice for customer",
        "Post invoice to accounts receivable",
        "Send invoice to customer",
        "Receive payment from customer",
        "Apply payment to invoice",
        "Post payment and settle invoice"
      ],
      "triggers": [
        "manual",
        "workflow"
      ]
    },
    {
      "description": "Close a fiscal period and prepare financial statements.",
      "entities": [
        "FiscalPeriod",
        "GeneralLedger",
        "LedgerAccount",
        "JournalEntry"
      ],
      "label": {
        "en": "Period Closing"
      },
      "name": "PeriodClosing",
      "steps": [
        "Review and post all pending transactions",
        "Perform adjustments (accruals, deferrals)",
        "Revalue foreign currency balances",
        "Run allocation rules",
        "Generate financial reports (trial balance, P&L, balance sheet)",
        "Close the period"
      ],
      "triggers": [
        "manual",
        "scheduled"
      ]
    },
    {
      "description": "Create and approve a budget for a fiscal year.",
      "entities": [
        "Budget",
        "LedgerAccount",
        "FiscalPeriod"
      ],
      "label": {
        "en": "Budget Planning"
      },
      "name": "BudgetPlanning",
      "steps": [
        "Define budget plan structure",
        "Enter budget amounts by account and period",
        "Review and adjust budget",
        "Approve budget",
        "Load budget into general ledger for control"
      ],
      "triggers": [
        "manual",
        "workflow"
      ]
    }
  ],
  "rules": [
    {
      "description": "A journal entry's debits must equal its credits before posting.",
      "enforced": "before-post",
      "label": {
        "en": "Balanced Entry"
      },
      "name": "BalancedEntry",
      "severity": "error"
    },
    {
      "description": "Debits and credits must be posted to appropriate account types (e.g., asset accounts normally have debit balances).",
      "enforced": "before-post",
      "label": {
        "en": "Account Type Validation"
      },
      "name": "AccountTypeValidation",
      "severity": "warning"
    },
    {
      "description": "Transactions can only be posted to open fiscal periods.",
      "enforced": "before-post",
      "label": {
        "en": "Period Status Check"
      },
      "name": "PeriodStatusCheck",
      "severity": "error"
    },
    {
      "description": "All lines in a journal entry must use the same currency unless multicurrency is enabled.",
      "enforced": "before-post",
      "label": {
        "en": "Currency Consistency"
      },
      "name": "CurrencyConsistency",
      "severity": "error"
    },
    {
      "description": "Required fields (e.g., account, date, amount) must be filled before posting.",
      "enforced": "before-post",
      "label": {
        "en": "Mandatory Fields"
      },
      "name": "MandatoryFields",
      "severity": "error"
    },
    {
      "description": "Expenditures must not exceed available budget when budget control is active.",
      "enforced": "before-post",
      "label": {
        "en": "Budget Control"
      },
      "name": "BudgetControl",
      "severity": "error"
    },
    {
      "description": "Purchase invoice amounts must match purchase order or receipt within tolerance.",
      "enforced": "before-post",
      "label": {
        "en": "Invoice Matching"
      },
      "name": "InvoiceMatching",
      "severity": "warning"
    }
  ],

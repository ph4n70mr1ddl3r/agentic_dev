  "rules": [
    {
      "description": "A journal entry's debits must equal its credits before posting.",
      "enforced": "before-post",
      "label": {
        "en": "Balanced Entry"
      },
      "name": "BalancedEntry",
      "severity": "error"
    },
    {
      "description": "The sum of line amounts on an invoice must equal the total amount.",
      "enforced": "before-post",
      "label": {
        "en": "Invoice Total Match"
      },
      "name": "InvoiceTotalMatch",
      "severity": "error"
    },
    {
      "description": "A payment amount cannot exceed the remaining balance of the invoice.",

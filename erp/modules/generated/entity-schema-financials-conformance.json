        },
        "name": "BadTransactional",
        "scope": "transactional"
      },
      "schema": "https://agentic.dev/platform-spec/schemas/entity.schema.json",
      "source": "constraint:ADR-0004"
    },
    {
      "expect": "invalid",
      "name": "rejects-missing-id-field",
      "rationale": "Every entity must have a guid field named 'id'.",

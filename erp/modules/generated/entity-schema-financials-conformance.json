    {
      "expect": "valid",
      "name": "represents-company",
      "rationale": "The entity schema must represent a D365 Company (legal entity / master data).",
      "sample": {
        "companyScoped": false,
        "fields": [
          {
            "label": {
              "en": "ID"
            },
            "name": "id",
            "type": "guid"
          },
          {
            "label": {
              "en": "Name"
            },
            "name": "name",
            "type": "text"
          },
          {
            "label": {
              "en": "Base Currency"
            },
            "name": "baseCurrency",
            "type": "text"
          }
        ],
        "id": "company",
        "label": {
          "en": "Company"
        },
        "name": "Company",
        "scope": "master"
      },
      "schema": "https://agentic.dev/platform-spec/schemas/entity.schema.json",
      "source": "d365-financials-reference/Company"
    },

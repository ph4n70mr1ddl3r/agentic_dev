      "schema": "https://agentic.dev/platform-spec/schemas/entity.schema.json",
      "source": "constraint:entity-schema"
    },
    {
      "expect": "invalid",
      "name": "rejects-picklist-without-options",
      "rationale": "Picklist fields must include a non-empty 'picklist.options' array.",

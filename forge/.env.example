# DeepSeek (OpenAI-compatible). Get a key at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...

# Model: deepseek-v4-flash (cheap) or deepseek-v4-pro.
# (deepseek-chat / deepseek-reasoner are deprecated 2026-07-24.)
DEEPSEEK_MODEL=deepseek-v4-flash

# Thinking mode: disabled (cheap, default for future hats) or enabled (reasons
# first; more tokens, better for planning/architecture). The CEO thinks by default
# regardless; pass `forge ceo --no-thinking` to force the cheap path.
# DEEPSEEK_THINKING=disabled

# Reasoning effort (only when thinking enabled): high | max
# DEEPSEEK_REASONING_EFFORT=high

# Max output tokens per call (prevents JSON truncation).
# DEEPSEEK_MAX_TOKENS=8192

# Per-request HTTP timeout in seconds (thinking mode can be slow).
# DEEPSEEK_TIMEOUT_SECS=180
